# Your own Privy app ID (free signup at https://dashboard.privy.io).
VITE_PRIVY_APP_ID=

# p2p.me's Privy provider app ID (the global / cross-app wallet provider).
# Obtain this from p2p.me / the Privy ecosystem. The login button targets it.
VITE_P2P_PROVIDER_APP_ID=

# Address printed by `npm run deploy` at the project root.
VITE_CONTRACT_ADDRESS=
